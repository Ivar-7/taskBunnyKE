<div class="container mt-5">
  <div class="row">
    <div class="col-12 text-center">
      <p style="color: green"><%= notice %></p>
    </div>
  </div>

  <div class="row">
    <div class="col-12 text-center">
      <h1 class="display-4">Reviews</h1>
    </div>
  </div>

  <div class="row">
    <div class="col-8 offset-2">
      <div id="reviews">
        <% @reviews.each do |review| %>
          <div class="card mb-4">
            <%= render review %>
            <div class="card-body">
              <p class="card-text">
                <%= link_to "Show this review", review, class: "btn btn-info" %>
              </p>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-12 text-center mt-4">
      <%= link_to "New review", new_review_path, class: "btn btn-success" %>
    </div>
  </div>
</div>
