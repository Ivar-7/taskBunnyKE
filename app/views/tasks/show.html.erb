<div class="container mt-5">
  <div class="row">
    <div class="col-12 text-center">
      <p style="color: green"><%= notice %></p>
    </div>
  </div>

  <div class="row">
    <div class="col-6 offset-3">
      <div id="<%= dom_id(@task) %>" class="card">
        <div class="card-body">
          <%= render @task %>
          <div class="text-center mt-3">
            <%= link_to "Edit this task", edit_task_path(@task), class: "btn btn-primary" %> |
            <%= link_to "Back to tasks", tasks_path, class: "btn btn-secondary" %>
          </div>
          <div class="text-center mt-3">
            <%= button_to "Destroy this task", @task, method: :delete, class: "btn btn-danger" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
