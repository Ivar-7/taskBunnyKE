<div class="container mt-5">
  <div class="row">
    <div class="col-6 offset-3">
      <div id="<%= dom_id(task) %>" class="card">
        <div class="card-body">
          <h4 class="card-title">Task Details</h4>
          <div class="card-text">
            <p><strong>Tasker:</strong> <%= task.tasker_id %></p>
            <p><strong>Service:</strong> <%= task.service_id %></p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
