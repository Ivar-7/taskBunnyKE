<div class="container mt-5">
  <div class="row">
    <div class="col-12 text-center">
      <h1 class="display-4">Services</h1>
    </div>
  </div>

  <div class="row">
    <% @services.each do |service| %>
      <div class="col-4">
        <%= render service %>
        <p class="mt-3">
          <%= link_to "Show this service", service, class: "btn btn-primary" %>
        </p>
      </div>
    <% end %>
  </div>

  <div class="row">
    <div class="col-12 text-center mt-4">
      <%= link_to "New service", new_service_path, class: "btn btn-success" %>
    </div>
  </div>
</div>
